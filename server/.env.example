# ============================================================
# Konfigurasi Database PostgreSQL
# ============================================================
# Ganti "postgres" dengan username PostgreSQL Anda
# Ganti "PASSWORD_ANDA" dengan password PostgreSQL Anda
# Ganti "spmb" dengan nama database yang anda buat
DATABASE_URL=postgresql://postgres:PASSWORD_ANDA@localhost:5432/spmb

# ============================================================
# Konfigurasi JWT (Keamanan Token Login)
# ============================================================
# Isi dengan string acak yang panjang dan susah ditebak
JWT_SECRET=ganti-dengan-string-rahasia-yang-susah-ditebak-2026

# ============================================================
# Konfigurasi Server
# ============================================================
PORT=3001
UPLOAD_DIR=./uploads

# ============================================================
# (Opsional) Konfigurasi Notifikasi Email - via Resend
# ============================================================
# Buat akun di https://resend.com untuk mendapatkan API key
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=spmb@domain-sekolah.com
